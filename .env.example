# ── Sanity CMS ────────────────────────────────────────────────────────────────
# Create a project at https://sanity.io/manage → get your projectId
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Read token for server-side draft previews (optional for public site)
# Create at sanity.io/manage → API → Tokens → Add API Token (Viewer)
SANITY_API_READ_TOKEN=

# ── Site ──────────────────────────────────────────────────────────────────────
# Your production URL — used in sitemap, OG tags, canonical URLs
NEXT_PUBLIC_SITE_URL=https://atlanticeee.com
